// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Role {
  ADMIN
  VENDOR
  WHOLESALER
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum CommissionStatus {
  PENDING
  COLLECTED
}

enum InvoiceStatus {
  UNPAID
  PAID
}

// ---------- MODÈLES PRINCIPAUX ----------

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?
  role          Role
  vendorProfile Vendor?
  wholesalerProfile Wholesaler?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model Vendor {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  businessName    String
  businessType    String?
  phone           String
  location        String?
  country         String?
  currency        String          @default("XOF")
  clients         Client[]
  vendorProducts  VendorProduct[]
  customProducts  CustomProduct[]
  transactions    Transaction[]
  orders          Order[]
  stockMovements  StockMovement[]

  @@index([userId])
}

model Wholesaler {
  id                  String              @id @default(cuid())
  userId              String              @unique
  user                User                @relation(fields: [userId], references: [id])
  businessName        String
  phone               String
  location            String?
  currency            String              @default("XOF")
  featured            Boolean             @default(false)
  wholesalerProducts  WholesalerProduct[]
  customProducts      CustomProduct[]
  orders              Order[]

  @@index([userId])
}

model Client {
  id                String        @id @default(cuid())
  vendorId          String
  vendor            Vendor        @relation(fields: [vendorId], references: [id])
  name              String
  phone             String
  email             String?
  debtBalance       Int           @default(0)
  preferredLanguage String        @default("fr")
  consentGiven      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  transactions      Transaction[]
  smsLogs           SmsLog[]

  @@index([vendorId])
  @@index([vendorId, createdAt])
}

model DefaultProduct {
  id               String             @id @default(cuid())
  nameFr           String
  nameWolof        String
  brand            String?
  category         String
  unit             String
  defaultPrice     Int
  imageUrl         String?
  createdAt        DateTime           @default(now())
  sponsoredProduct SponsoredProduct[]

  @@index([category])
}

model CustomProduct {
  id           String      @id @default(cuid())
  vendorId     String?
  wholesalerId String?
  name         String
  nameWolof    String?
  unit         String
  price        Int
  stock        Int         @default(0)
  imageUrl     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  vendor       Vendor?     @relation(fields: [vendorId], references: [id])
  wholesaler   Wholesaler? @relation(fields: [wholesalerId], references: [id])

  @@index([vendorId])
  @@index([wholesalerId])
}

model VendorProduct {
  id            String   @id @default(cuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  productId     String
  productType   String
  price         Int
  stock         Int      @default(0)
  lowStockAlert Int      @default(5)
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
  @@index([vendorId, stock])
}

model WholesalerProduct {
  id           String     @id @default(cuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  productId    String
  productType  String
  price        Int
  originalPrice Int?
  currency     String
  conditioning String
  stock        Int        @default(0)
  updatedAt    DateTime   @updatedAt

  @@index([wholesalerId])
  @@index([wholesalerId, stock])
}

model Transaction {
  id               String        @id @default(cuid())
  vendorId         String
  vendor           Vendor        @relation(fields: [vendorId], references: [id])
  clientId         String
  client           Client        @relation(fields: [clientId], references: [id])
  items            Json
  totalCents       Int
  paymentStatus    PaymentStatus
  amountPaid       Int           @default(0)
  remaining        Int           @default(0)
  platformFeeCents Int           @default(0)
  hash             String        @unique
  vendorIp         String?
  createdAt        DateTime      @default(now())
  payments         Payment[]
  commissions      PlatformCommission[]

  @@index([vendorId])
  @@index([clientId])
  @@index([vendorId, createdAt])
  @@index([paymentStatus])
}

model Payment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amountCents   Int
  previousDebt  Int
  newDebt       Int
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@index([createdAt])
}

model PlatformCommission {
  id            String           @id @default(cuid())
  type          String           // 'SALE' | 'ORDER'
  amountCents   Int
  status        CommissionStatus @default(PENDING)
  transactionId String?
  transaction   Transaction?     @relation(fields: [transactionId], references: [id])
  orderId       String?
  order         Order?           @relation(fields: [orderId], references: [id])
  createdAt     DateTime         @default(now())

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Order {
  id               String      @id @default(cuid())
  wholesalerId     String
  wholesaler       Wholesaler  @relation(fields: [wholesalerId], references: [id])
  vendorId         String
  vendor           Vendor      @relation(fields: [vendorId], references: [id])
  items            Json
  status           OrderStatus
  totalCents       Int
  platformFeeCents Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  messages         Message[]
  commissions      PlatformCommission[]

  @@index([vendorId])
  @@index([wholesalerId])
  @@index([status])
  @@index([vendorId, createdAt])
  @@index([wholesalerId, createdAt])
}

model SmsLog {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id])
  phone    String
  message  String
  language String
  status   String
  sentAt   DateTime @default(now())

  @@index([clientId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model StockMovement {
  id             String   @id @default(cuid())
  vendorId       String
  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  productId      String
  productType    String
  quantityChange Int
  reason         String
  referenceId    String?
  createdAt      DateTime @default(now())

  @@index([vendorId])
  @@index([vendorId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  userRole  String
  question  String
  answer    String
  language  String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Message {
  id           String   @id @default(cuid())
  senderId     String
  senderType   String
  receiverId   String
  receiverType String
  content      String
  read         Boolean  @default(false)
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id])
  createdAt    DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@index([read])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SponsoredProduct {
  id              String         @id @default(cuid())
  defaultProductId String
  defaultProduct  DefaultProduct @relation(fields: [defaultProductId], references: [id])
  active          Boolean        @default(true)
  homepageOrder   Int?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime       @default(now())

  @@index([active])
  @@index([homepageOrder])
}

model Invoice {
  id        String        @id @default(cuid())
  userId    String
  period    String
  amountCents Int
  status    InvoiceStatus @default(UNPAID)
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([status])
}

model DataSubscription {
  id           String   @id @default(cuid())
  companyName  String
  contactEmail String
  startDate    DateTime
  endDate      DateTime
  monthlyFee   Int
  active       Boolean  @default(true)
}

model ClickTracking {
  id        String   @id @default(cuid())
  userId    String?
  linkType  String
  target    String
  ip        String?
  createdAt DateTime @default(now())
}
